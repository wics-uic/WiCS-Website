        <img src="src/assets/logo.png" alt="Logo" class="w-7 h-auto">
    </a>
    <button id="menu-btn" class="menu-btn flex justify-end pr-3 text-white text-2xl">
        &equiv;
    </button>
</div>



<div class="hamburger-menu flex flex-col items-start justify-start" id="mobile-menu">
    <button id="close-btn" class="close-btn flex justify-end text-3xl text-white">
        &times;
    </button>
    <a href='/'><img src="src/assets/logo.png" alt="Logo" class="w-10 h-auto"></a>
    
    <div class="menu-item flex flex-col">
        <a href="/events" class="dropdown">Events</a>
        <div class="dropdown-menu flex flex-col">
            <a href="/events">Calendar</a>
            <a href="/events">Upcoming Events</a>
            <a href="/events">Past Events</a>
        </div>
    </div>
    <a href="/resources">Resources</a>
