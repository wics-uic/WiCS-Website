    <a href="/team">Our Team</a>
    <a href="/about">About</a>
    <a href="/collaborate">Collaborate</a>
</div>

<script >
    // This script will run in the browser after the HTML is parsed
    document.addEventListener('DOMContentLoaded', () => {
        const menuButton = document.getElementById('menu-btn');
        const sidebar = document.querySelector('.hamburger-menu') as HTMLElement;

        if (menuButton && sidebar) {
            menuButton.addEventListener('click', () => {
                sidebar.style.display = 'flex';
                console.log('Sidebar shown via addEventListener!'); // Debugging log
            });
        } else {
            console.error("Error: Could not find menu button or sidebar element.");
        }

        const closeButton = document.querySelector('.close-btn') as HTMLElement;
        if (closeButton && sidebar) {
            closeButton.addEventListener('click', () => {
                sidebar.style.display = 'none'; // <--- THIS IS THE LINE THAT HIDES IT AGAIN!
                console.log('Sidebar hidden via close button!');
            });
        }
    });

</script>

<style>
    .navbar {
        position: fixed;
