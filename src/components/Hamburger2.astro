        justify-content: space-between;
        z-index: 999;
    }
    .navbar a, button {
        text-shadow: 1px 2px 2px rgba(0, 0, 0, 0.3); /* horizontal, vertical, blur, color */
        text-decoration: none;
    }

    
    
    /* sidebar styling */ 

    .hamburger-menu {
        position: fixed;
        top: 0;
        right: 0;
        height: 100vh;
        width: 250px;
        max-width: 90vw;
        z-index: 1000;
        background-color: #ffb8b9d9;
        backdrop-filter: blur(10px);
        box-shadow: -10px 0px 10px rgba(0,0,0,0.1);
        /* display: none; */
    }
    .hamburger-menu a, button {
        color: white;
        text-shadow: 1px 2px 2px rgba(0, 0, 0, 0.3); /* horizontal, vertical, blur, color */
        width: 100%;
        padding: 10px;
        padding-left: 30px;
        text-decoration: none;
    }
    .hamburger-menu a:hover {
        background-color: #f6a3a4d9;
    }

    /* does not show */
    @media (min-width: 1051px){
